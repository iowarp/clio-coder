{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/.antigravitycli",
			"!**/.claude",
			"!**/.clio",
			"!**/.clio-benchmark",
			"!**/dist",
			"!**/node_modules",
			"!**/*.log",
			"!**/docs/.superpowers",
			"!**/*.html"
		]
	}
}
