{
	"name": "@iowarp/clio-coder",
	"version": "0.2.3",
	"description": "Coding agent for HPC and scientific-software developers, part of IOWarp's CLIO ecosystem of agentic science.",
	"keywords": [
		"ai",
		"agentic-ai",
		"agentic-coding",
		"agentic-science",
		"coding",
		"repository",
		"terminal",
		"developer-tools",
		"llm",
		"agents",
		"model-targets",
		"multi-agent",
		"coding-agents",
		"software-engineering",
		"research-software",
		"scientific-computing",
		"hpc",
		"clio",
		"iowarp"
	],
	"type": "module",
	"license": "Apache-2.0",
	"author": "Anthony Kougkas <a.kougkas@gmail.com> (https://github.com/akougkas)",
	"contributors": [
		"IOWarp <https://iowarp.ai>",
		"Gnosis Research Center <https://grc.iit.edu/>"
	],
	"homepage": "https://iowarp.ai",
	"bugs": "https://github.com/iowarp/clio-coder/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/iowarp/clio-coder.git"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"bin": {
		"clio": "dist/cli/index.js"
	},
	"files": [
		"dist",
		"assets/banner.png",
		"assets/banner.webp",
		"assets/clio-coder-logo-*.webp",
		"scripts/install-local.sh",
		"scripts/uninstall-local.sh",
		"benchmarks/**",
		"src/domains/agents/builtins/**",
		"src/domains/providers/models/**",
		"src/domains/prompts/fragments/**",
		"docs/*.md",
		"README.md",
		"CHANGELOG.md",
		"CONTRIBUTING.md",
		"SECURITY.md",
		"CODE_OF_CONDUCT.md",
		"NOTICE",
		"LICENSE",
		"CLIO.md",
		"damage-control-rules.yaml"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"typecheck": "tsc -p tsconfig.tests.json",
		"format": "biome format --write .",
		"lint": "biome check .",
		"check:boundaries": "node --import tsx --test 'tests/boundaries/**/*.test.ts'",
		"test:file": "node --import tsx --test",
		"test:smoke": "node --import tsx --test 'tests/smoke/**/*.test.ts'",
		"test:contracts": "node --import tsx --test 'tests/contracts/**/*.test.ts'",
		"test": "node --import tsx --test 'tests/contracts/**/*.test.ts' 'tests/smoke/**/*.test.ts' 'tests/boundaries/**/*.test.ts'",
		"ci": "npm run typecheck && npm run lint && npm run build && npm run test",
		"ci:release": "npm run ci && node scripts/check-dist.mjs",
		"test:live": "node scripts/live-smoke.mjs",
		"bench:models": "node benchmarks/clio-model-suite.mjs",
		"install:local": "bash scripts/install-local.sh",
		"uninstall:local": "bash scripts/uninstall-local.sh",
		"hooks:install": "bash scripts/install-hooks.sh",
		"prepublishOnly": "npm run ci:release",
		"skills:pin": "node --import tsx scripts/pin-skills.ts"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "0.3.178",
		"@earendil-works/pi-agent-core": "0.79.1",
		"@earendil-works/pi-ai": "0.79.1",
		"@earendil-works/pi-tui": "0.79.1",
		"@lmstudio/sdk": "1.5.0",
		"@silvia-odwyer/photon-node": "^0.3.4",
		"chalk": "5.6.2",
		"diff": "9.0.0",
		"esbuild": "0.28.0",
		"ollama": "0.6.3",
		"tree-sitter-wasms": "^0.1.13",
		"typebox": "1.1.38",
		"typescript": "6.0.3",
		"undici": "8.3.0",
		"uuid": "14.0.0",
		"web-tree-sitter": "^0.20.8",
		"yaml": "2.9.0"
	},
	"overrides": {
		"@anthropic-ai/sdk": "0.94.0",
		"ip-address": "10.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/node": "24.12.2",
		"node-pty": "1.1.0",
		"tsup": "8.5.1",
		"tsx": "4.21.0"
	}
}
